generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RoundStatus {
  STARTING
  BETTING
  PLAYING
  ENDED
}

model Round {
  id         String      @id @default(uuid())
  nounce     Int         @unique
  serverSeed String
  status     RoundStatus @default(STARTING)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  bets Bet[]
}

enum BetStatus {
  ACTIVE
  CANCELED
  CASHED_OUT
  LOST
}

model Bet {
  id        String    @id @default(uuid())
  roundId   String
  userEmail String
  amount    Int
  cashoutAt Int?
  status    BetStatus @default(ACTIVE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  round     Round     @relation(fields: [roundId], references: [id])

  @@index([roundId])
  @@index([userEmail])
  @@index([roundId, userEmail], name: "round_user_idx")
}

enum EventType {
  BET_DONE
  BET_WINNER
}
model Outbox {
  id        String   @id @default(uuid())
  eventType EventType
  userEmail String
  amount    Int
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
  
  @@index([processed])
}
